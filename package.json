{
  "name": "alo-jetk-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:init": "cap init",
    "cap:add": "cap add android && cap add ios",
    "cap:sync": "cap sync",
    "cap:open": "cap open android",
    "cap:open:ios": "cap open ios",
    "android": "npm run build && cap sync android && cap open android",
    "ios": "npm run build && cap sync ios && cap open ios",
    "android:build": "npm run build && cap sync android && cd android && .\\gradlew.bat assembleRelease && cd ..",
    "android:build:debug": "npm run build && cap sync android && cd android && .\\gradlew.bat assembleDebug && cd ..",
    "android:clean": "cd android && .\\gradlew.bat clean && cd ..",
    "android:build:web": "npm run build && cap sync android",
    "ios:build": "npm run build && cap sync ios",
    "ios:build:web": "npm run build && cap sync ios",
    "test": "vitest"
  },
  "dependencies": {
    "@capacitor/android": "^5.7.8",
    "@capacitor/app": "^5.0.7",
    "@capacitor/camera": "^5.0.10",
    "@capacitor/cli": "^7.4.2",
    "@capacitor/core": "^5.7.8",
    "@capacitor/geolocation": "^5.0.8",
    "@capacitor/haptics": "^5.0.7",
    "@capacitor/ios": "^5.7.8",
    "@capacitor/keyboard": "^5.0.7",
    "@capacitor/local-notifications": "^5.0.8",
    "@capacitor/preferences": "^5.0.8",
    "@capacitor/push-notifications": "^5.1.0",
    "@capacitor/splash-screen": "^5.0.7",
    "@capacitor/status-bar": "^5.0.7",
    "@supabase/supabase-js": "^2.39.7",
    "buffer": "^6.0.3",
    "howler": "^2.2.4",
    "leaflet": "^1.9.4",
    "leaflet-routing-machine": "^3.2.12",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.22.3",
    "use-sound": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/howler": "^2.2.11",
    "@types/leaflet": "^1.9.8",
    "@types/leaflet-routing-machine": "^3.2.8",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^1.3.1"
  }
}
